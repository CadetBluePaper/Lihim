{
  "manifest_version": 3,
  "name": "Lihim Autofill",
  "version": "1.0",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": { "default_popup": "popup.html" }
}
